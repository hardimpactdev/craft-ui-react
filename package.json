{
  "name": "@hardimpactdev/craft-ui-react",
  "version": "0.0.1",
  "description": "A React component library and Vite toolchain for building Laravel + React + Inertia apps. Built on Base UI and shadcn with Agentation integration.",
  "author": "Hard Impact <hello@hardimpact.dev>",
  "license": "MIT",
  "homepage": "https://github.com/hardimpactdev/craft-ui-react#readme",
  "bugs": {
    "url": "https://github.com/hardimpactdev/craft-ui-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hardimpactdev/craft-ui-react.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./vite": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./agentation": {
      "types": "./dist/agentation-plugin.d.mts",
      "default": "./dist/agentation-plugin.mjs"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "shadcn build",
    "build:lib": "vp pack src/vite/index.ts src/vite/agentation-plugin.ts --dts --format esm --out-dir dist",
    "build:storybook": "storybook build",
    "serve": "npx http-server public -p 4100 -c-1 --cors"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@inertiajs/react": "^3.0.0",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.0",
    "storybook": "^10.3.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@inertiajs/vite": "^3.0.0",
    "@laravel/vite-plugin-wayfinder": "^0.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "laravel-vite-plugin": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vite-plugin-run": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@storybook/addon-mcp": "^0.4.2",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-is": "^19.2.4",
    "react-resizable-panels": "^4.7.5",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "^8.0.2",
    "vite-plus": "^0.1.14"
  }
}
